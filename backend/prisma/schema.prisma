generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
  schemas  = ["public"]
}

model Profile {
  id         String   @id @default(uuid())
  email      String?  @unique
  full_name  String?
  avatar_url String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  landingPages LandingPage[] @relation("UserLandingPages")
  @@schema("public")
}

model LandingPage {
  id        String   @id @default(uuid())
  user_id   String
  title     String
  briefing  Json?
  content   Json
  status    String
  slug      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user      Profile  @relation(fields: [user_id], references: [id], name: "UserLandingPages")
  versions  LandingPageVersion[]
  @@index([user_id])
  @@schema("public")
}

model LandingPageVersion {
  id              String   @id @default(uuid())
  landing_page_id String
  version_number  Int
  title           String
  briefing        Json?
  content         Json
  reason          String?
  created_at      DateTime @default(now())
  landingPage     LandingPage @relation(fields: [landing_page_id], references: [id], onDelete: Cascade)

  @@unique([landing_page_id, version_number])
  @@index([landing_page_id, created_at])
  @@schema("public")
}

model AnonymousPreview {
  id         String   @id @default(uuid())
  ip_address String?
  content    Json
  briefing   Json?
  expires_at DateTime
  created_at DateTime @default(now())
  @@schema("public")
}
